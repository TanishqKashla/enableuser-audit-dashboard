# Neon Postgres — create a project at https://console.neon.tech and copy both URLs.
# The pooled URL (ends with -pooler.*.neon.tech) is what the app uses at runtime.
# The direct URL (no -pooler) is used by Prisma migrations.
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# 32+ byte random string. Generate one with: openssl rand -base64 48
AUTH_SECRET=7M7dD7nvQIrtF3GqKnINHMTKg4CceboBwFFI6/BNAo6etA2mwhtZcDp+KxU1cPmR

# One-time seed for the admin account. After first seed you can unset these.
SEED_ADMIN_EMAIL="admin@enableuser.in"
SEED_ADMIN_PASSWORD="enableuser@2580"
